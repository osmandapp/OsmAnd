<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:background="?attr/list_background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/content_padding_small">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/content_padding"
            android:paddingBottom="@dimen/content_padding_small"
            android:text="@string/shared_string_type"
            android:textColor="?android:textColorSecondary"
            android:textSize="@dimen/default_desc_text_size"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/row_filter_type_all"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_filter_show_all"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_filter_type_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_type_now"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_filter_visible_now"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_filter_type_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_type_tonight"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_filter_visible_tonight"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_filter_type_tonight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/list_divider" />

        <LinearLayout
            android:id="@+id/row_filter_naked_eye"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_filter_naked_eye"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_naked_eye"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/list_divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/content_padding"
            android:paddingTop="@dimen/content_padding_small"
            android:paddingBottom="@dimen/content_padding_small"
            android:text="@string/favourites_edit_dialog_category"
            android:textColor="?android:textColorSecondary"
            android:textSize="@dimen/default_desc_text_size"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/row_filter_category_all"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shared_string_all"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_solar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_solar_system"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_solar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_constellations"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_constellations"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_constellations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_stars"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_stars"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_stars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_nebulas"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_nebulas"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_nebulas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_clusters"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_star_clusters"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_clusters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_filter_category_deep_sky"
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_row_min_height"
            android:layout_marginBottom="@dimen/content_padding_small"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/content_padding">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/astro_deep_sky"
                android:textColor="?android:textColorPrimary"
                android:textSize="@dimen/default_list_text_size" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/checkbox_filter_category_deep_sky"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
