<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/mode_container"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:gravity="center_vertical"
	android:orientation="horizontal"
	android:paddingHorizontal="@dimen/content_padding"
	android:paddingVertical="@dimen/content_padding_small">

	<ImageView
		android:id="@+id/mode_icon"
		android:layout_width="@dimen/standard_icon_size"
		android:layout_height="@dimen/standard_icon_size"
		android:layout_marginEnd="@dimen/content_padding"
		tools:ignore="ContentDescription"
		tools:src="@drawable/widget_developer_ram_day" />

	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_weight="1"
		android:orientation="vertical">

		<net.osmand.plus.widgets.TextViewEx
			style="@style/TitleStyle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/shared_string_mode"
			android:textColor="?android:textColorPrimary" />

		<net.osmand.plus.widgets.TextViewEx
			android:id="@+id/selected_mode_type"
			style="@style/DescStyle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:textColor="?android:textColorSecondary"
			tools:text="@string/memory_used_settings" />

	</LinearLayout>

</LinearLayout>