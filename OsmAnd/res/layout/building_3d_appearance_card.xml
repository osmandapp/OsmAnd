<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?attr/list_background_color"
	android:orientation="vertical">

	<include
		android:id="@+id/header_container"
		layout="@layout/bottom_sheet_item_with_two_text" />

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="?attr/bg_color"
		android:orientation="vertical">

	</LinearLayout>

	<LinearLayout
		android:id="@+id/color_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:minHeight="@dimen/bottom_sheet_medium_list_item_height"
		android:orientation="horizontal">

		<androidx.appcompat.widget.AppCompatImageView
			android:id="@+id/icon_appearance"
			android:layout_width="@dimen/standard_icon_size"
			android:layout_height="@dimen/standard_icon_size"
			android:layout_marginStart="@dimen/content_padding"
			android:layout_marginTop="@dimen/content_padding"
			android:layout_marginBottom="@dimen/content_padding"
			android:tint="?attr/default_icon_color"
			app:srcCompat="@drawable/ic_action_appearance" />

		<net.osmand.plus.widgets.TextViewEx
			style="@style/TitleStyle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_gravity="center_vertical"
			android:layout_marginStart="@dimen/content_padding_double"
			android:layout_weight="1"
			android:text="@string/shared_string_color"
			android:textColor="?android:textColorPrimary" />

		<net.osmand.plus.widgets.TextViewEx
			style="@style/TitleStyle"
			android:id="@+id/color_scheme_name"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="center_vertical"
			android:paddingHorizontal="@dimen/content_padding"
			android:text="@string/shared_string_transparency"
			android:textColor="?android:textColorSecondary" />

	</LinearLayout>

	<include layout="@layout/divider_half_item" />

	<LinearLayout
		android:id="@+id/opacity_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:minHeight="@dimen/bottom_sheet_medium_list_item_height"
		android:orientation="horizontal">

		<androidx.appcompat.widget.AppCompatImageView
			android:layout_width="@dimen/standard_icon_size"
			android:layout_height="@dimen/standard_icon_size"
			android:layout_marginStart="@dimen/content_padding"
			android:layout_marginTop="@dimen/content_padding"
			android:layout_marginBottom="@dimen/content_padding"
			android:tint="?attr/default_icon_color"
			app:srcCompat="@drawable/ic_action_opacity" />

		<net.osmand.plus.widgets.TextViewEx
			style="@style/TitleStyle"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_gravity="center_vertical"
			android:layout_marginStart="@dimen/content_padding_double"
			android:layout_weight="1"
			android:text="@string/gpx_visibility_txt"
			android:textColor="?android:textColorPrimary" />

		<net.osmand.plus.widgets.TextViewEx
			style="@style/TitleStyle"
			android:id="@+id/opacity_value"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:gravity="end"
			android:layout_gravity="center_vertical"
			android:paddingHorizontal="@dimen/content_padding"
			android:textColor="?android:textColorSecondary"
			tools:text="25%" />

	</LinearLayout>

</LinearLayout>